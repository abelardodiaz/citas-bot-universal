# App
APP_NAME=citas-bot-universal
LOG_LEVEL=INFO

# Meta WhatsApp Business
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=

# LLM (Anthropic default; DeepSeek planned for v0.2.0+)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=1024

# Database
DATABASE_URL=sqlite+aiosqlite:///./citas_bot.db
DATABASE_ECHO=false

# Business config (single JSON env var so the .env stays compact)
BUSINESS_INFO_JSON='{"name":"Barberia Demo","hours":"Lun-Vie 9-18","address":"Av. Principal 123, CDMX","phone":"+5215555555555","description":"Cortes clasicos y modernos"}'
BUSINESS_TIMEZONE=America/Mexico_City
APPOINTMENT_DURATION_MINUTES=30
